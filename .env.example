# RSK Network
RSK_NETWORK=testnet          # testnet (chainId 31) or mainnet (chainId 30)

# Wallet
PRIVATE_KEY=0x...            # private key of the signing wallet (keep secret!)
WALLET_ADDRESS=0x...         # public address for balance queries

# Contracts
ORACLE_ADDRESS=0x...         # price oracle wallet address (ZwickToken deploy)
ZWICK_TOKEN_ADDRESS=0x...    # deployed ZwickToken contract (after deploy.js)
ZWICK_BYTECODE=0x...         # compiled ZwickToken bytecode (from hardhat artifacts)

# AI Agent
ANTHROPIC_API_KEY=sk-ant-... # Anthropic API key for Claude agent
